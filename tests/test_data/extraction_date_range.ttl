@prefix dct: <http://purl.org/dc/terms/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.com/dataset5> a dcat:Dataset ;
    dct:title "Test Dataset" ;
    dct:temporal <http://example.com/period1> .

<http://example.com/period1> a dct:PeriodOfTime ;
    dcat:startDate "2020-01-01"^^xsd:date ;
    dcat:endDate "2023-12-31"^^xsd:date .
