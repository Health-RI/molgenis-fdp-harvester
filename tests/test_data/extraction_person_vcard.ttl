@prefix dct: <http://purl.org/dc/terms/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<http://example.com/person_vcard> a vcard:Kind ;
    dct:identifier "person-vcard-001" ;
    vcard:fn "Dr. Sarah Johnson" ;
    vcard:hasEmail "mailto:sarah.johnson@example.org" .
